<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
    {%- endif -%}
    
    <title>{{ page_title }}</title>
    
    {%- if page_description -%}
      <meta name="description" content="{{ page_description | escape }}">
    {%- endif -%}
    
    {%- comment -%} Cargar CSS de Dream Tape {%- endcomment -%}
    {{ 'dream-tape-styles.css' | asset_url | stylesheet_tag }}
    
    {%- comment -%} Si necesitas base.css también {%- endcomment -%}
    {{ 'base.css' | asset_url | stylesheet_tag }}
    
    {{ content_for_header }}
    
    {%- comment -%} Google Fonts para Dream Tape {%- endcomment -%}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  </head>

  <body class="dream-tape-page">
    {{ content_for_layout }}
    
    {%- comment -%} Cargar JavaScript de Dream Tape {%- endcomment -%}
    <script src="{{ 'dream-tape.js' | asset_url }}" defer></script>
  </body>
</html>
