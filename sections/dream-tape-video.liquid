{% comment %}
  DREAM TAPE - VIDEO EMBED
  Sección para video embebido (YouTube, Vimeo, etc.)
{% endcomment %}

<section class="dt-section">
  <div class="dt-container">
    
    {%- comment -%} Título {%- endcomment -%}
    {%- if section.settings.title != blank -%}
      <h2 class="dt-section-h2 dt-animate">{{ section.settings.title }}</h2>
    {%- endif -%}
    
    {%- comment -%} Video Embed {%- endcomment -%}
    <div class="dt-animate" style="max-width: 800px; margin: 3rem auto 0;">
      
      {%- if section.settings.video_url != blank -%}
        <div style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; border-radius: var(--dt-border-radius); box-shadow: 0 8px 32px rgba(99, 102, 241, 0.2);">
          
          {%- comment -%} YouTube {%- endcomment -%}
          {%- if section.settings.video_url contains 'youtube.com' or section.settings.video_url contains 'youtu.be' -%}
            {%- assign video_id = section.settings.video_url | split: 'v=' | last | split: '/' | last | split: '&' | first -%}
            <iframe 
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
              src="https://www.youtube.com/embed/{{ video_id }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>
          
          {%- comment -%} Vimeo {%- endcomment -%}
          {%- elsif section.settings.video_url contains 'vimeo.com' -%}
            {%- assign video_id = section.settings.video_url | split: '/' | last -%}
            <iframe 
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
              src="https://player.vimeo.com/video/{{ video_id }}"
              frameborder="0"
              allow="autoplay; fullscreen; picture-in-picture"
              allowfullscreen
            ></iframe>
          
          {%- comment -%} Fallback - URL directa {%- endcomment -%}
          {%- else -%}
            <iframe 
              style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
              src="{{ section.settings.video_url }}"
              frameborder="0"
              allowfullscreen
            ></iframe>
          {%- endif -%}
          
        </div>
      {%- else -%}
        
        {%- comment -%} Placeholder si no hay video {%- endcomment -%}
        <div style="aspect-ratio: 16/9; background: var(--dt-card-bg); border-radius: var(--dt-border-radius); display: flex; align-items: center; justify-content: center; border: 1px solid var(--dt-card-border);">
          <div style="text-align: center; color: var(--dt-text-secondary);">
            <svg width="80" height="80" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="opacity: 0.3; margin: 0 auto 1rem;">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z"/>
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <p style="margin: 0; font-size: 14px;">Agrega una URL de video</p>
          </div>
        </div>
        
      {%- endif -%}
      
    </div>
    
  </div>
</section>

{% schema %}
{
  "name": "Dream Tape Video",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Título",
      "default": "Míralo en acción"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "URL del Video",
      "info": "Soporta YouTube y Vimeo"
    }
  ],
  "presets": [
    {
      "name": "Dream Tape Video"
    }
  ]
}
{% endschema %}
